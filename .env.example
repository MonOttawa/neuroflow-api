# Neuroflow API — Environment Variables
# Copy to .env and fill in values

# JWT secret — MUST be set in production (min 32 chars random)
JWT_SECRET=change-me-use-openssl-rand-base64-32

# CORS origin — domain of the PWA in production
# Use "*" for local development only
CORS_ORIGIN=*

# Port (inside container)
PORT=3001

# SQLite DB path (inside container)
DB_PATH=/data/neuroflow.db
